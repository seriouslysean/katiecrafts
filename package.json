{
  "name": "katiecrafts.com",
  "version": "2.0.0",
  "type": "module",
  "description": "Katie Crafts blog - migrated from WordPress to Astro",
  "homepage": "https://www.katiecrafts.com",
  "bugs": {
    "url": "https://github.com/seriouslysean/katiecrafts.com/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seriouslysean/katiecrafts.com.git"
  },
  "license": "MIT",
  "author": "Sean Kennedy <sean@codeserious.com>",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && cp CNAME dist/CNAME",
    "tool:import-wordpress": "tsx tools/import-wordpress.ts",
    "tool:cleanup-posts": "tsx tools/cleanup-posts.ts",
    "tool:export-posts": "tsx tools/export-posts.ts",
    "lint": "oxlint . --ignore-path .oxlintignore",
    "lint:fix": "oxlint . --fix --ignore-path .oxlintignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.4.1",
    "astro": "^5.14.5",
    "entities": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/yargs": "^17.0.33",
    "axios": "^1.7.9",
    "dotenv": "^17.0.0",
    "node-html-parser": "^6.1.13",
    "oxlint": "^1.11.0",
    "rehype-parse": "^9.0.0",
    "rehype-stringify": "^10.0.0",
    "unist-util-visit": "^5.0.0",
    "sharp": "^0.34.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "yargs": "^17.7.2"
  }
}
