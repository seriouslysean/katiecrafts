{
  "name": "katiecrafts.com",
  "version": "2.0.0",
  "type": "module",
  "description": "Katie Crafts blog - migrated from WordPress to Astro",
  "homepage": "https://www.katiecrafts.com",
  "bugs": {
    "url": "https://github.com/seriouslysean/katiecrafts.com/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seriouslysean/katiecrafts.com.git"
  },
  "license": "MIT",
  "author": "Sean Kennedy <sean@codeserious.com>",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && cp CNAME dist/CNAME",
    "tool:import-wordpress": "tsx tools/import-wordpress.ts",
    "tool:cleanup-posts": "tsx tools/cleanup-posts.ts",
    "tool:export-posts": "tsx tools/export-posts.ts",
    "new-post": "tsx tools/new-post.ts",
    "lint": "oxlint . --ignore-path .oxlintignore",
    "lint:fix": "oxlint . --fix --ignore-path .oxlintignore",
    "typecheck": "tsc --noEmit",
    "audit:content": "tsx tools/audit-content.ts",
    "audit:markdown": "markdownlint-cli2 \"src/content/blog/**/*.md\"",
    "audit:links": "tsx tools/audit-links.ts",
    "audit:html": "html-validate \"dist/**/*.html\"",
    "audit": "npm run audit:content && npm run audit:markdown && npm run build && npm run audit:html && npm run audit:links"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "astro": "^6.3.3",
    "entities": "^8.0.0",
    "minisearch": "^7.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/yargs": "^17.0.35",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "html-validate": "^11.1.0",
    "linkinator": "^7.6.1",
    "markdownlint-cli2": "^0.22.1",
    "node-html-parser": "^7.1.0",
    "oxlint": "^1.65.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "yargs": "^18.0.0"
  }
}
