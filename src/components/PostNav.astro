---
import type { BlogEntry } from '~utils/taxonomy';

interface Props {
  prev?: BlogEntry;
  next?: BlogEntry;
}

const { prev, next } = Astro.props;
---

{(prev || next) ? (
  <nav class="post-nav" aria-label="More posts">
    {prev ? (
      <a class="post-nav__link post-nav__link--prev" href={`/blog/${prev.id}/`}>
        <span class="post-nav__direction">← Older</span>
        <span class="post-nav__title">{prev.data.title}</span>
      </a>
    ) : null}
    {next ? (
      <a class="post-nav__link post-nav__link--next" href={`/blog/${next.id}/`}>
        <span class="post-nav__direction">Newer →</span>
        <span class="post-nav__title">{next.data.title}</span>
      </a>
    ) : null}
  </nav>
) : null}

<style>
  .post-nav {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .post-nav__link {
    display: grid;
    gap: 0.2rem;
    padding: 0.85rem 1.15rem;
    border: 1px solid var(--color-border);
    border-radius: 0.7rem;
    background: var(--color-panel);
    color: var(--color-text);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .post-nav__link:hover,
  .post-nav__link:focus-visible {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 0.75rem 1.5rem rgba(150, 88, 138, 0.1);
    text-decoration: none;
  }

  .post-nav__direction {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  .post-nav__title {
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
  }

  .post-nav__link--next {
    text-align: right;
  }

  @media (min-width: 40rem) {
    .post-nav {
      flex-direction: row;
      gap: 1rem;
    }

    .post-nav__link {
      flex: 1 1 0;
    }

    .post-nav__link--next:only-child {
      margin-left: auto;
      flex: 0 1 50%;
    }

    .post-nav__link--prev:only-child {
      margin-right: auto;
      flex: 0 1 50%;
    }
  }
</style>
