---
type MakeHref = (page: number) => string;

interface Props {
  currentPage: number;
  totalPages: number;
  makeHref: MakeHref;
  label?: string;
  previousLabel?: string;
  nextLabel?: string;
}

type PageItem = number | 'ellipsis';

const buildPageItems = (totalPages: number, currentPage: number): PageItem[] => {
  const pages: PageItem[] = [];
  const range: number[] = [];
  const delta = 1;

  for (let page = 1; page <= totalPages; page += 1) {
    const isEdgePage = page === 1 || page === totalPages;
    const isNearCurrent = Math.abs(page - currentPage) <= delta;
    if (isEdgePage || isNearCurrent) {
      range.push(page);
    }
  }

  let previous = 0;
  for (const page of range) {
    if (previous !== 0) {
      if (page - previous === 2) {
        pages.push(previous + 1);
      } else if (page - previous > 2) {
        pages.push('ellipsis');
      }
    }
    pages.push(page);
    previous = page;
  }

  return pages;
};

const {
  currentPage,
  totalPages,
  makeHref,
  label = 'Pagination',
  previousLabel = '← Newer Posts',
  nextLabel = 'Older Posts →',
} = Astro.props as Props;

const hasPrevious = currentPage > 1;
const hasNext = currentPage < totalPages;
const previousHref = hasPrevious ? makeHref(currentPage - 1) : undefined;
const nextHref = hasNext ? makeHref(currentPage + 1) : undefined;
const pageItems = buildPageItems(totalPages, currentPage);
---

{totalPages > 1 ? (
  <nav class="pagination" aria-label={label}>
    {hasPrevious ? (
      <a class="pagination__link" href={previousHref} rel="prev">
        {previousLabel}
      </a>
    ) : (
      <span class="pagination__link pagination__link--disabled">{previousLabel}</span>
    )}

    <ul class="pagination__pages">
      {pageItems.map(item =>
        item === 'ellipsis' ? (
          <li class="pagination__ellipsis" aria-hidden="true">…</li>
        ) : item === currentPage ? (
          <li>
            <span class="pagination__page pagination__page--current" aria-current="page">{item}</span>
          </li>
        ) : (
          <li>
            <a class="pagination__page" href={makeHref(item)} aria-label={`Go to page ${item}`}>{item}</a>
          </li>
        )
      )}
    </ul>

    {hasNext ? (
      <a class="pagination__link" href={nextHref} rel="next">
        {nextLabel}
      </a>
    ) : (
      <span class="pagination__link pagination__link--disabled">{nextLabel}</span>
    )}
  </nav>
) : null}

<style>
  .pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .pagination__link {
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .pagination__link:hover,
  .pagination__link:focus-visible {
    text-decoration: underline;
  }

  .pagination__link--disabled {
    color: var(--color-muted);
    cursor: not-allowed;
    opacity: 0.6;
  }

  .pagination__pages {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pagination__page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.75rem;
    min-height: 2.75rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .pagination__page:hover,
  .pagination__page:focus-visible {
    background-color: var(--color-accent);
    color: #ffffff;
    border-color: transparent;
    text-decoration: none;
  }

  .pagination__page--current {
    background-color: var(--color-accent);
    color: #ffffff;
    border-color: transparent;
    cursor: default;
  }

  .pagination__ellipsis {
    color: var(--color-muted);
    font-weight: 700;
  }
</style>
