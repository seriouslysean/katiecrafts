---
const inputId = 'site-search-input';
const resultsId = 'site-search-results';
const panelId = 'site-search-panel';
---

<div class="search" data-search>
  <button
    type="button"
    class="search__toggle"
    aria-controls={panelId}
    aria-expanded="false"
    aria-label="Open search"
    data-search-toggle
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </button>
  <div class="search__panel" id={panelId} hidden>
    <form class="search__form" role="search" autocomplete="off">
      <label class="visually-hidden" for={inputId}>Search posts</label>
      <input
        id={inputId}
        type="search"
        name="q"
        class="search__input"
        placeholder="Search posts…"
        aria-controls={resultsId}
        autocomplete="off"
      />
      <button type="submit" class="visually-hidden">Search</button>
    </form>
    <p class="search__empty" data-search-empty hidden>No matches.</p>
    <ul id={resultsId} class="search__results" hidden></ul>
  </div>
</div>

<script>
  type Doc = { id: string; title: string; excerpt: string; categories: string; tags: string };

  const root = document.querySelector<HTMLElement>('[data-search]');
  if (root) {
    const toggle = root.querySelector<HTMLButtonElement>('[data-search-toggle]')!;
    const panel = root.querySelector<HTMLElement>('.search__panel')!;
    const form = root.querySelector<HTMLFormElement>('.search__form')!;
    const input = root.querySelector<HTMLInputElement>('input[name="q"]')!;
    const results = root.querySelector<HTMLUListElement>('.search__results')!;
    const empty = root.querySelector<HTMLElement>('[data-search-empty]')!;

    let index: import('minisearch').default<Doc> | undefined;
    let loading: Promise<void> | undefined;
    let debounce: number | undefined;

    async function ensureIndex() {
      if (index) return;
      if (loading) return loading;
      loading = (async () => {
        const [{ default: MiniSearch }, response] = await Promise.all([
          import('minisearch'),
          fetch('/search-index.json'),
        ]);
        const documents = (await response.json()) as Doc[];
        index = new MiniSearch<Doc>({
          fields: ['title', 'excerpt', 'categories', 'tags'],
          storeFields: ['id', 'title'],
          searchOptions: {
            fuzzy: 0.2,
            prefix: true,
            boost: { title: 2, tags: 1.2 },
          },
        });
        index.addAll(documents);
      })();
      return loading;
    }

    function render(items: Array<{ id: string; title: string }>, hasQuery: boolean) {
      results.replaceChildren();
      if (!hasQuery) {
        results.hidden = true;
        empty.hidden = true;
        return;
      }
      if (!items.length) {
        results.hidden = true;
        empty.hidden = false;
        return;
      }
      const fragment = document.createDocumentFragment();
      for (const item of items) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `/blog/${item.id}/`;
        a.textContent = item.title;
        li.appendChild(a);
        fragment.appendChild(li);
      }
      results.appendChild(fragment);
      results.hidden = false;
      empty.hidden = true;
    }

    async function runSearch() {
      const query = input.value.trim();
      if (!query) {
        render([], false);
        return;
      }
      await ensureIndex();
      if (!index) return;
      const hits = index.search(query).slice(0, 10);
      render(
        hits.map(hit => ({ id: hit.id as string, title: hit.title as string })),
        true,
      );
    }

    function open() {
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close search');
      void ensureIndex();
      window.requestAnimationFrame(() => input.focus());
    }

    function close() {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open search');
    }

    toggle.addEventListener('click', () => {
      if (panel.hidden) open();
      else close();
    });

    input.addEventListener('input', () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(runSearch, 100);
    });

    form.addEventListener('submit', event => event.preventDefault());

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && !panel.hidden) {
        close();
        toggle.focus();
      }
    });

    document.addEventListener('click', event => {
      if (panel.hidden) return;
      if (root.contains(event.target as Node)) return;
      close();
    });
  }
</script>

<style>
  .search {
    position: absolute;
    top: clamp(0.75rem, 2vw, 1.25rem);
    right: clamp(0.75rem, 2vw, 1.25rem);
    z-index: 30;
  }

  .search__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-panel);
    color: var(--color-accent);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .search__toggle:hover,
  .search__toggle:focus-visible {
    background: rgba(250, 241, 247, 0.85);
    border-color: var(--color-accent);
    outline: none;
  }

  .search__toggle:focus-visible {
    box-shadow: 0 0 0 3px rgba(150, 88, 138, 0.25);
  }

  .search__toggle svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .search__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(20rem, calc(100vw - 1.5rem));
    padding: 0.85rem;
    background: var(--color-panel);
    border: 1px solid var(--color-border);
    border-radius: 0.7rem;
    box-shadow: 0 1rem 2rem rgba(44, 45, 51, 0.1);
  }

  .search__panel[hidden] {
    display: none;
  }

  .search__form {
    margin: 0;
  }

  .search__input {
    width: 100%;
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 0.45rem;
    background: var(--color-background);
    font: inherit;
    color: inherit;
  }

  .search__input:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(150, 88, 138, 0.18);
  }

  .search__results {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    max-height: min(60vh, 22rem);
    overflow-y: auto;
  }

  .search__results[hidden] {
    display: none;
  }

  .search__results :global(li + li) {
    margin-top: 0.15rem;
  }

  .search__results :global(a) {
    display: block;
    padding: 0.45rem 0.55rem;
    border-radius: 0.4rem;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.3;
  }

  .search__results :global(a:hover),
  .search__results :global(a:focus-visible) {
    background: rgba(250, 241, 247, 0.9);
    color: var(--color-accent);
    text-decoration: none;
  }

  .search__empty {
    margin: 0.6rem 0 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .search__empty[hidden] {
    display: none;
  }

  @media (min-width: 40rem) {
    .search__panel {
      width: 22rem;
    }
  }
</style>
