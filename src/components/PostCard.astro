---
import { Image } from 'astro:assets';
import type { BlogEntry } from '~utils/taxonomy';

interface Props {
  post: BlogEntry;
}

const { post } = Astro.props;
const { title, excerpt, categories, featuredImage } = post.data;
const postUrl = `/blog/${post.id}/`;
const previewText = excerpt ?? '';
const primaryCategories = categories.slice(0, 2);
---

<article class="post-card">
  <a class="post-card__link" href={postUrl} aria-label={`Read more about ${title}`}>
    {featuredImage ? (
      <div class="post-card__image">
        <Image
          src={featuredImage.src}
          alt={featuredImage.alt ?? title}
          widths={[320, 640, 960]}
          sizes="(min-width: 720px) 33vw, 100vw"
          loading="lazy"
          decoding="async"
        />
      </div>
    ) : null}

    <div class="post-card__body">
      {primaryCategories.length ? (
        <p class="post-card__meta">
          {primaryCategories.map((category, index) => (
            <>
              {index > 0 ? ' · ' : null}
              <span>{category.name}</span>
            </>
          ))}
        </p>
      ) : null}

      <h2 class="post-card__title">{title}</h2>

      {previewText ? (
        <div class="post-card__excerpt" set:html={previewText} />
      ) : null}

      <span class="post-card__cta">Read More</span>
    </div>
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    background: var(--color-panel);
    overflow: hidden;
    box-shadow: 0 0.75rem 1.5rem rgba(150, 88, 138, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover,
  .post-card:focus-within {
    transform: translateY(-2px);
    box-shadow: 0 1.25rem 2.5rem rgba(150, 88, 138, 0.12);
  }

  .post-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-card__link:focus-visible {
    outline: 0.2rem solid rgba(150, 88, 138, 0.35);
    outline-offset: 0.35rem;
    text-decoration: none;
  }

  .post-card__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f6f0f4;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .post-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: clamp(1.1rem, 2vw + 0.9rem, 1.6rem);
    flex: 1;
  }

  .post-card__meta {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #51445e;
  }

  .post-card__title {
    margin: 0;
    font-size: clamp(1.25rem, 1vw + 1.1rem, 1.5rem);
    line-height: 1.35;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .post-card__excerpt {
    color: var(--color-text);
    font-size: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__excerpt :global(p) {
    margin: 0;
  }

  .post-card__cta {
    margin-top: auto;
    font-weight: 600;
    color: var(--color-accent);
  }

  .post-card__link:hover,
  .post-card__link:focus-visible {
    color: inherit;
    text-decoration: none;
  }

  .post-card__link:hover .post-card__title,
  .post-card__link:focus-visible .post-card__title {
    color: var(--color-accent);
  }

  .post-card__link:hover .post-card__cta,
  .post-card__link:focus-visible .post-card__cta {
    color: var(--color-text);
  }
</style>
