---
import { Image } from 'astro:assets';
import type { BlogEntry } from '~utils/taxonomy';

interface Props {
  post: BlogEntry;
}

const { post } = Astro.props;
const { title, excerpt, categories, featuredImage } = post.data;
const postUrl = `/blog/${post.id}/`;
const previewText = excerpt ?? '';
const primaryCategories = categories.slice(0, 2);
---

<article class="post-card">
  <a class="post-card__link" href={postUrl} aria-label={`Read more about ${title}`}>
    {featuredImage ? (
      <div class="post-card__image">
        <Image
          src={featuredImage.src}
          alt={featuredImage.alt ?? title}
          widths={[320, 640, 960]}
          sizes="(min-width: 720px) 33vw, 100vw"
          loading="lazy"
          decoding="async"
        />
      </div>
    ) : null}

    <div class="post-card__body">
      {primaryCategories.length ? (
        <p class="post-card__meta">
          {primaryCategories.map((category, index) => (
            <>
              {index > 0 ? ' · ' : null}
              <span>{category.name}</span>
            </>
          ))}
        </p>
      ) : null}

      <h2 class="post-card__title">{title}</h2>

      {previewText ? (
        <div class="post-card__excerpt" set:html={previewText} />
      ) : null}

      <span class="post-card__cta">Read More</span>
    </div>
  </a>
</article>
