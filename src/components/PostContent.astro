---
import type { PostEntry } from '~utils/posts';
import { formatPublishedDate } from '~utils/posts';

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const { title, featuredImage, content, categories, tags, publishedDate } = post.data;
---

<article class="post">
  <header class="post__header">
    <p class="post__meta">
      <time dateTime={publishedDate}>{formatPublishedDate(publishedDate)}</time>
      {categories.length ? (
        <span class="post__meta-categories">
          <span aria-hidden="true"> · </span>
          {categories.map((category, index) => (
            <>
              {index > 0 ? ', ' : null}
              <a href={`/category/${category.slug}/`}>{category.name}</a>
            </>
          ))}
        </span>
      ) : null}
    </p>
    <h1 class="post__title">{title}</h1>
  </header>

  {featuredImage ? (
    <figure class="post__featured">
      <img
        src={featuredImage.src}
        alt={featuredImage.alt ?? title}
        width={featuredImage.width}
        height={featuredImage.height}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </figure>
  ) : null}

  <div class="post__content" set:html={content} />

  {(categories.length || tags.length) ? (
    <footer class="post__footer">
      {categories.length ? (
        <p class="post__taxonomy">
          <strong>Categories:</strong>{' '}
          {categories.map((category, index) => (
            <>
              {index > 0 ? ', ' : null}
              <a href={`/category/${category.slug}/`}>{category.name}</a>
            </>
          ))}
        </p>
      ) : null}
      {tags.length ? (
        <p class="post__taxonomy">
          <strong>Tags:</strong>{' '}
          {tags.map((tag, index) => (
            <>
              {index > 0 ? ', ' : null}
              <a href={`/tag/${tag.slug}/`}>{tag.name}</a>
            </>
          ))}
        </p>
      ) : null}
    </footer>
  ) : null}
</article>
