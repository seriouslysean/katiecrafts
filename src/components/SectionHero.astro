---
interface Props {
  title: string;
  subtitle?: string;
  size?: 'default' | 'narrow';
}

const { title, subtitle, size = 'default' } = Astro.props;
---

<section class="hero" class:list={{ 'hero--narrow': size === 'narrow' }}>
  <div class="hero__inner">
    <h1 class="hero__title">{title}</h1>
    {subtitle ? <p class="hero__subtitle">{subtitle}</p> : null}
    <slot />
  </div>
</section>

<style>
  .hero {
    --hero-width: min(64rem, 100%);
    --hero-inner-width: min(46rem, 100%);
    margin: 0 auto clamp(2rem, 4vw, 3rem);
    padding: clamp(1.75rem, 3vw + 1rem, 3rem);
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    background: rgba(250, 241, 247, 0.75);
    text-align: center;
    width: var(--hero-width);
  }

  .hero--narrow {
    --hero-width: min(46rem, 100%);
    --hero-inner-width: min(46rem, 100%);
  }

  .hero__inner {
    display: grid;
    gap: 0.75rem;
    margin: 0 auto;
    max-width: var(--hero-inner-width);
  }

  .hero__title {
    margin-bottom: 0.75rem;
    font-size: clamp(1.75rem, 2vw + 1.5rem, 2.6rem);
    font-weight: 700;
    color: var(--color-accent);
  }

  .hero__subtitle {
    margin: 0 auto;
    max-width: var(--hero-inner-width);
    font-size: 1.05rem;
  }
</style>
