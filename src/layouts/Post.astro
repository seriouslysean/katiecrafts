---
import Layout from '~layouts/Layout.astro';

type TaxonomyValue = string | { slug?: string; name?: string };

type Frontmatter = {
  title?: string;
  slug?: string;
  publishedDate?: string;
  date?: string;
  categories?: TaxonomyValue[];
  tags?: TaxonomyValue[];
  featuredImage?: {
    src: string;
    width?: number;
    height?: number;
    alt?: string;
  };
  excerpt?: string;
};

const props = Astro.props as Record<string, any>;
const frontmatter: Frontmatter = props.frontmatter ?? props;

const title = frontmatter.title ?? 'Katie Crafts post';
const slug = frontmatter.slug ?? '';
const publishedDate = frontmatter.publishedDate ?? frontmatter.date;
const categories = Array.isArray(frontmatter.categories) ? frontmatter.categories : [];
const tags = Array.isArray(frontmatter.tags) ? frontmatter.tags : [];
const featuredImage = frontmatter.featuredImage;
const excerpt = frontmatter.excerpt;

const formatSlug = (value: string) =>
  value
    .split(/[\\s_-]+/)
    .filter(Boolean)
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');

const normalizeTaxonomy = (values: TaxonomyValue[]) => {
  return values
    .map(value => {
      if (typeof value === 'string') {
        const slugValue = value.trim();
        if (!slugValue) return undefined;
        return {
          slug: slugValue,
          label: formatSlug(slugValue),
        };
      }
      if (value && typeof value === 'object') {
        const slugValue =
          typeof value.slug === 'string' && value.slug.trim()
            ? value.slug.trim()
            : typeof value.name === 'string'
              ? value.name.trim()
              : '';
        if (!slugValue) return undefined;
        const label =
          typeof value.name === 'string' && value.name.trim()
            ? value.name.trim()
            : formatSlug(slugValue);
        return {
          slug: slugValue,
          label,
        };
      }
      return undefined;
    })
    .filter((entry): entry is { slug: string; label: string } => Boolean(entry));
};

const categoryMeta = normalizeTaxonomy(categories);
const tagMeta = normalizeTaxonomy(tags);

const publishedIso = publishedDate ? new Date(`${publishedDate}T00:00:00Z`).toISOString() : undefined;
const formattedDate = publishedIso
  ? new Date(publishedIso).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : undefined;

const description =
  excerpt && excerpt.trim().length
    ? excerpt.trim()
    : 'Katie Crafts blog post';

const canonical = slug ? `/blog/${slug}/` : '/blog/';
const ogImage = featuredImage?.src
  ? featuredImage.src.startsWith('/')
    ? featuredImage.src
    : `/blog/${slug}/${featuredImage.src.replace(/^\.\//, '')}`
  : undefined;
---

<Layout
  title={`${title} | Katie Crafts`}
  description={description}
  canonical={canonical}
  image={ogImage}
  imageAlt={featuredImage?.alt ?? title}
  imageWidth={featuredImage?.width}
  imageHeight={featuredImage?.height}
  isArticle
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  section={categoryMeta[0]?.label}
  tags={tagMeta.map(tag => tag.label)}
>
  <article class="post">
    <header class="post__header">
      <p class="post__meta">
        {formattedDate ? <time dateTime={publishedIso}>{formattedDate}</time> : null}
        {categoryMeta.length ? (
          <span class="post__meta-categories">
            <span aria-hidden="true"> · </span>
            {categoryMeta.map((category, idx) => (
              <>
                {idx > 0 ? ', ' : null}
                <a href={`/category/${category.slug}/`}>{category.label}</a>
              </>
            ))}
          </span>
        ) : null}
      </p>
      <h1 class="post__title">{title}</h1>
    </header>

    {featuredImage ? (
      <figure class="post__featured">
        <img
          src={featuredImage.src}
          alt={featuredImage.alt ?? title}
          width={featuredImage.width}
          height={featuredImage.height}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>
    ) : null}

    <div class="post__content">
      <slot />
    </div>

    {(categoryMeta.length || tagMeta.length) ? (
      <footer class="post__footer">
        {categoryMeta.length ? (
          <p class="post__taxonomy">
            <strong>Categories:</strong>{' '}
            {categoryMeta.map((category, idx) => (
              <>
                {idx > 0 ? ', ' : null}
                <a href={`/category/${category.slug}/`}>{category.label}</a>
              </>
            ))}
          </p>
        ) : null}
        {tagMeta.length ? (
          <p class="post__taxonomy">
            <strong>Tags:</strong>{' '}
            {tagMeta.map((tag, idx) => (
              <>
                {idx > 0 ? ', ' : null}
                <a href={`/tag/${tag.slug}/`}>{tag.label}</a>
              </>
            ))}
          </p>
        ) : null}
      </footer>
    ) : null}
  </article>
</Layout>
