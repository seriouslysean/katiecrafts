---
import { getCollection } from 'astro:content';
import Layout from '~layouts/Layout.astro';
import PostCard from '~components/PostCard.astro';
import SectionHero from '~components/SectionHero.astro';
import Paginator from '~components/Paginator.astro';
import {
  getTagSummaries,
  getPostsByTag,
  type BlogEntry,
} from '~utils/taxonomy';
import { paginatePosts, POSTS_PER_PAGE } from '~utils/pagination';

interface Props {
  slug: string;
  name: string;
  posts: BlogEntry[];
  pageNumber: number;
  totalPages: number;
  totalCount: number;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = getTagSummaries(posts);

  return tags.map(tag => {
    const postsForTag = getPostsByTag(posts, tag.slug);
    const totalPages = Math.max(1, Math.ceil(postsForTag.length / POSTS_PER_PAGE));
    const { posts: pagePosts } = paginatePosts(postsForTag, 1, POSTS_PER_PAGE);

    return {
      params: { slug: tag.slug },
      props: {
        slug: tag.slug,
        name: tag.name,
        posts: pagePosts,
        pageNumber: 1,
        totalPages,
        totalCount: postsForTag.length,
      },
    };
  });
}

const { slug, name, posts, pageNumber, totalPages, totalCount } = Astro.props as Props;
const canonicalPath = `/tag/${slug}/`;
const title = `Posts tagged ${name} | Katie Crafts`;
const description = `Posts tagged ${name} on Katie Crafts.`;
const countLabel = `${totalCount} ${totalCount === 1 ? 'post' : 'posts'}`;
const leadPost = posts[0];
const leadTitle = leadPost?.data.title;
const makeHref = (page: number) => (page === 1 ? `/tag/${slug}/` : `/tag/${slug}/page/${page}/`);
---

<Layout
  title={title}
  description={description}
  canonical={canonicalPath}
  imageAlt={leadTitle}
>
  <SectionHero title={name} subtitle={countLabel} />

  <section class="listing">
    <h2 class="listing__title">Latest Posts</h2>

    <div class="listing__grid">
      {posts.map(post => (
        <PostCard post={post} />
      ))}
    </div>

    <Paginator
      currentPage={pageNumber}
      totalPages={totalPages}
      makeHref={makeHref}
      previousLabel="← Newer Posts"
      nextLabel="Older Posts →"
      label="Tag pagination"
    />
  </section>
</Layout>
