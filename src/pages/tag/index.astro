---
import { getCollection } from 'astro:content';
import Layout from '~layouts/Layout.astro';
import SectionHero from '~components/SectionHero.astro';
import { getTagSummaries } from '~utils/taxonomy';

const posts = await getCollection('blog');
const tags = getTagSummaries(posts);
---

<Layout
  title="Browse by Tag | Katie Crafts"
  description="Explore Katie Crafts blog posts grouped by tag."
  canonical="/tag/"
>
  <SectionHero title="Browse by Tag" subtitle="Find posts by theme, season, and more." />

  <section class="taxonomy-index">
    <ul class="taxonomy-list">
      {tags.map(tag => (
        <li class="taxonomy-card">
          <a class="taxonomy-card__link" href={`/tag/${tag.slug}/`}>
            <span class="taxonomy-card__name">{tag.name}</span>
            <span class="taxonomy-card__count">
              {tag.count} {tag.count === 1 ? 'post' : 'posts'}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
