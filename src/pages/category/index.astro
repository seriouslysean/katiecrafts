---
import Layout from '~layouts/Layout.astro';
import SectionHero from '~components/SectionHero.astro';
import { getAllPosts, getCategorySummaries } from '~utils/posts';

const posts = await getAllPosts();
const categories = getCategorySummaries(posts);
---

<Layout
  title="Browse by Category | Katie Crafts"
  description="Explore Katie Crafts blog posts grouped by category."
  canonical="/category/"
>
  <SectionHero title="Browse by Category" subtitle="Jump into the topics you love the most." />

  <section class="taxonomy-index">
    <ul class="taxonomy-list">
      {categories.map(category => (
        <li class="taxonomy-card">
          <a href={`/category/${category.slug}/`}>{category.name}</a>
          <span class="taxonomy-card__count">
            {category.count} {category.count === 1 ? 'post' : 'posts'}
          </span>
        </li>
      ))}
    </ul>
  </section>
</Layout>
