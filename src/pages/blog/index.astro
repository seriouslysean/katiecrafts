---
import Layout from '~layouts/Layout.astro';
import PostCard from '~components/PostCard.astro';
import Paginator from '~components/Paginator.astro';
import { getAllPosts, paginatePosts, POSTS_PER_PAGE } from '~utils/posts';

const posts = await getAllPosts();
const currentPage = 1;
const { posts: pagePosts, totalPages } = paginatePosts(posts, currentPage, POSTS_PER_PAGE);
const leadPost = pagePosts[0];
const leadImage = leadPost?.data.featuredImage;
const leadTitle = leadPost?.data.title;
const makeHref = (page: number) => (page === 1 ? '/blog/' : `/blog/page/${page}/`);
---

<Layout
  title="Blog | Katie Crafts"
  description="Discover creative DIY projects, crafts, and inspiration from Katie Crafts."
  canonical="/blog/"
  image={leadImage?.src}
  imageAlt={leadImage?.alt ?? leadTitle}
  imageWidth={leadImage?.width}
  imageHeight={leadImage?.height}
>
  <section class="listing">
    <h1 class="listing__title">Latest Posts</h1>
    <div class="listing__grid">
      {pagePosts.map(post => (
        <PostCard post={post} />
      ))}
    </div>

    <Paginator
      currentPage={currentPage}
      totalPages={totalPages}
      makeHref={makeHref}
      previousLabel="← Newer Posts"
      nextLabel="Older Posts →"
      label="Blog pagination"
    />
  </section>
</Layout>
