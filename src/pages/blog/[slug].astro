---
import Layout from '~layouts/Layout.astro';
import PostContent from '~components/PostContent.astro';
import { getAllPosts } from '~utils/posts';
import type { PostEntry } from '~utils/posts';

interface Props {
  post: PostEntry;
}

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props as Props;
const { title, excerpt, slug, featuredImage, categories, tags, publishedDate } = post.data;
const description = excerpt ? excerpt.replace(/<[^>]+>/g, '').slice(0, 160) : 'Katie Crafts blog post';
const canonicalPath = `/blog/${slug}/`;
const imageAlt = featuredImage?.alt ?? title;
const publishedIso = new Date(`${publishedDate}T00:00:00Z`).toISOString();
const section = categories[0]?.name;
const tagNames = tags.map(tag => tag.name);
---

<Layout
  title={`${title} | Katie Crafts`}
  description={description}
  canonical={canonicalPath}
  image={featuredImage?.src}
  imageAlt={imageAlt}
  imageWidth={featuredImage?.width}
  imageHeight={featuredImage?.height}
  isArticle
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  section={section}
  tags={tagNames}
>
  <PostContent post={post} />
</Layout>
