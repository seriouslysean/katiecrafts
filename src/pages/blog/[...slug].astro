---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '~layouts/Layout.astro';
import PostNav from '~components/PostNav.astro';
import ShareButtons from '~components/ShareButtons.astro';
import { sortByPublishedDate, type BlogEntry } from '~utils/taxonomy';
import { formatPublishedDate } from '~utils/pagination';

interface Props {
  post: BlogEntry;
  prev?: BlogEntry;
  next?: BlogEntry;
}

export async function getStaticPaths() {
  const posts = sortByPublishedDate(await getCollection('blog'));
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1],
      next: posts[i - 1],
    },
  }));
}

const { post, prev, next } = Astro.props as Props;
const { Content } = await render(post);

const { title, publishedDate, categories, tags, excerpt, featuredImage } = post.data;
const slug = post.id;
const publishedIso = publishedDate ? new Date(`${publishedDate}T00:00:00Z`).toISOString() : undefined;
const formattedDate = formatPublishedDate(publishedDate);
const description = excerpt?.trim() || 'Katie Crafts blog post';
const canonical = `/blog/${slug}/`;
const shareUrl = Astro.site ? new URL(canonical, Astro.site).href : canonical;
---

<Layout
  title={`${title} | Katie Crafts`}
  description={description}
  canonical={canonical}
  isArticle
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  section={categories[0]?.name}
  tags={tags.map(tag => tag.name)}
>
  <article class="post">
    <header class="post__header">
      <p class="post__meta">
        {formattedDate ? <time datetime={publishedIso}>{formattedDate}</time> : null}
        <span aria-hidden="true"> · </span>
        <span class="post__byline">By Katie</span>
        {categories.length ? (
          <span class="post__meta-categories">
            <span aria-hidden="true"> · </span>
            {categories.map((category, idx) => (
              <>
                {idx > 0 ? ', ' : null}
                <a href={`/category/${category.slug}/`}>{category.name}</a>
              </>
            ))}
          </span>
        ) : null}
      </p>
      <h1 class="post__title">{title}</h1>
    </header>

    {featuredImage ? (
      <figure class="post__featured">
        <Image
          src={featuredImage.src}
          alt={featuredImage.alt ?? title}
          widths={[480, 960, 1440]}
          sizes="(min-width: 960px) 960px, 100vw"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>
    ) : null}

    <div class="post__content">
      <Content />
    </div>

    {tags.length ? (
      <footer class="post__footer">
        <span class="post__footer-label">Tagged</span>
        <ul class="post__tags">
          {tags.map(tag => (
            <li>
              <a class="post__tag" href={`/tag/${tag.slug}/`}>{tag.name}</a>
            </li>
          ))}
        </ul>
      </footer>
    ) : null}

    <ShareButtons title={title} url={shareUrl} />

    <PostNav prev={prev} next={next} />
  </article>
</Layout>

<style>
  .post {
    width: min(46rem, 100%);
    margin: 0 auto;
    padding: clamp(1.75rem, 3vw + 1rem, 3rem);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: var(--color-panel);
    box-shadow: 0 1.5rem 3rem rgba(150, 88, 138, 0.08);
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .post > .post__footer,
  .post > :global(.share),
  .post > :global(.post-nav) {
    margin-top: clamp(0.25rem, 1vw, 0.75rem);
  }

  .post > :global(.post-nav) {
    padding-top: clamp(1rem, 2vw, 1.5rem);
    border-top: 1px solid var(--color-border);
  }

  .post__header {
    text-align: center;
    display: grid;
    gap: 0.75rem;
  }

  .post__meta {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post__meta-categories {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .post__meta-categories :global(a) {
    color: inherit;
  }

  .post__byline {
    color: var(--color-muted);
  }

  .post__title {
    margin: 0;
    font-size: clamp(2rem, 2.5vw + 1.5rem, 2.75rem);
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-accent);
  }

  .post__featured :global(img) {
    width: 100%;
    display: block;
    height: auto;
    border-radius: 0.75rem;
  }

  .post__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.65rem;
    padding-top: clamp(1rem, 2vw, 1.5rem);
    border-top: 1px solid var(--color-border);
  }

  .post__footer-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--color-muted);
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-panel);
    color: var(--color-accent);
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .post__tag:hover,
  .post__tag:focus-visible {
    background: rgba(250, 241, 247, 0.85);
    border-color: var(--color-accent);
    text-decoration: none;
  }
</style>
